# Example environment for docker-compose / webhook. Copy to .env and fill in.
# WEBHOOK_SECRET must match the secret configured on the GitHub webhook.
WEBHOOK_SECRET=replace-me-with-your-github-webhook-secret

# --- Kural Studio (AI image generation + Google Drive storage) -------------
# Full setup walkthrough: docs/KURAL_STUDIO_SETUP.md
# Only needed if you're running the `studio` service (image generation).

# Google AI Studio API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=replace-me-with-your-gemini-api-key
# Image-capable Gemini model id. Leave the default unless Google renames it.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# OAuth2 client (type: Desktop app) from Google Cloud Console, with the
# Drive API enabled — this is what lets the app write to YOUR Google Drive
# (not a service account's separate Drive).
GOOGLE_OAUTH_CLIENT_ID=replace-me-with-your-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-me-with-your-oauth-client-secret
# One-time token obtained by running: node server/get-refresh-token.js
GOOGLE_OAUTH_REFRESH_TOKEN=replace-me-with-your-oauth-refresh-token

# Drive folder id (from the folder's URL) that generated images are stored
# under, in a "Kural Studio/<kural id>/" subfolder structure.
GOOGLE_DRIVE_FOLDER_ID=replace-me-with-your-drive-folder-id
